VITE_SOLANA_CLUSTER=mainnet
VITE_SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Fill these after the mainnet programs are deployed.
VITE_GAME_STATE_PROGRAM_ID=
VITE_MARKET_PROGRAM_ID=

# Must match the PROTOCOL_ANTIMATTER_MINT compiled into game-state.
VITE_ANTIMATTER_MINT=

# Optional, only if MagicBlock mainnet endpoints are active for this build.
VITE_ER_RPC_ENDPOINT=
VITE_ER_DIRECT_RPC=

VITE_PUBLIC_APP_URL=https://chained-universe.vercel.app
